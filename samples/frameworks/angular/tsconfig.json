{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"experimentalDecorators": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
	},
	"angularCompilerOptions": {
		"strictTemplates": true,
	},
	"include": ["src/**/*.ts"],
}
