{
	"compilerOptions": {
		"target": "es2019",
		"outDir": "dist",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": false,
		"declaration": true,
		"declarationMap": true,
		"declarationDir": "./dist/types",
		"resolveJsonModule": true,
	},
	"include": ["src/**/*.ts"],
}
