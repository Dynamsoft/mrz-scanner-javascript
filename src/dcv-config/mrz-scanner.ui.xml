<style>
	/* Animation keyframes */
	@keyframes dce-rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	@keyframes dce-spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Scan spinner styles (used by MRZScannerView) */
	.dce-mn-scan-spinner {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 56px;
		height: 56px;
		margin: -28px 0 0 -28px;
		opacity: 0;
		transition: opacity 0.15s ease;
		pointer-events: none;
		z-index: 4;
	}

	.dce-mn-scan-spinner.dce-visible {
		opacity: 1;
	}

	.dce-mn-scan-spinner .dce-spinner-bg {
		fill: var(--mrz-spinner-background, rgba(0, 0, 0, 0.2));
	}

	.dce-mn-scan-spinner .dce-spinner-inner {
		animation: dce-spin 1.2s linear infinite;
		transform-origin: 28px 28px;
	}

	.dce-mn-scan-spinner .dce-spinner-inner path {
		fill: var(--mrz-spinner-color, #fff);
	}

	@media (prefers-reduced-motion: reduce) {
		.dce-mn-scan-spinner .dce-spinner-inner { animation: none; }
	}
</style>
